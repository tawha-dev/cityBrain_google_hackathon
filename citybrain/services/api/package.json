{
  "name": "@citybrain/api",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "start": "node dist/index.js",
    "db:migrate": "tsx --env-file=../../.env src/db/migrate.ts",
    "db:seed": "tsx --env-file=../../.env src/db/seed.ts"
  },
  "dependencies": {
    "@citybrain/agent-tools": "*",
    "@citybrain/shared": "*",
    "@google/generative-ai": "^0.24.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "pg": "^8.13.3",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.1.0",
    "ws": "^8.18.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.11.11",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/ws": "^8.5.14",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
