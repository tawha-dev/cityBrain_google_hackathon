# CityBrain dedicated ports (avoid conflicts with local Postgres :5432, other projects)
#   Postgres 5434 | Redis 6380 | API 4000 | Web 8180 | Vite dev 5174

# Database (host ports — use after: docker compose up postgres redis -d)
DATABASE_URL=postgresql://citybrain:citybrain@localhost:5434/citybrain
REDIS_URL=redis://localhost:6380

# API
PORT=4000
NODE_ENV=development
CORS_ORIGIN=*

# AI — Gemini (optional; Flash Lite has low daily caps in AI Studio)
GEMINI_API_KEY=
# REST API (not Live WebSocket): gemini-3-flash-preview = "Gemini 3 Flash"
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_MODEL_FALLBACK=gemini-2.5-flash

# OpenRouter — free :free models (comma-separated fallbacks, tried in order)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_MODEL_FALLBACK=openai/gpt-oss-120b:free,minimax/minimax-m2.5:free,deepseek/deepseek-v4-flash:free,google/gemma-4-31b-it:free
OPENROUTER_REFERER=http://localhost:4000
OPENROUTER_MAX_TOKENS=4096
# auto = OpenRouter first, then Gemini | openrouter | gemini
AI_PROVIDER=openrouter

# Live data feeds
OPENWEATHER_API_KEY=
NEWS_API_KEY=

# Google Maps (optional for live routes)
GOOGLE_MAPS_API_KEY=
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# Mobile / Web client (use PC LAN IP instead of localhost when testing on a physical phone)
EXPO_PUBLIC_API_URL=http://localhost:4000
EXPO_PUBLIC_WS_URL=ws://localhost:4000/ws

# Authority web dashboard (Vite dev server on 5174)
VITE_API_URL=http://localhost:4000
VITE_WS_URL=ws://localhost:4000/ws
VITE_GOOGLE_MAPS_API_KEY=
