{
  "name": "citybrain-ai",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "services/*",
    "apps/*"
  ],
  "overrides": {
    "metro": "0.81.5",
    "metro-config": "0.81.5",
    "metro-core": "0.81.5",
    "metro-runtime": "0.81.5",
    "metro-resolver": "0.81.5",
    "metro-cache": "0.81.5",
    "metro-source-map": "0.81.5",
    "metro-symbolicate": "0.81.5",
    "metro-transform-worker": "0.81.5",
    "metro-babel-transformer": "0.81.5",
    "metro-file-map": "0.81.5",
    "metro-cache-key": "0.81.5",
    "metro-transform-plugins": "0.81.5"
  },
  "scripts": {
    "build": "npm run build -w @citybrain/shared && npm run build -w @citybrain/agent-tools && npm run build -w @citybrain/api",
    "dev:api": "npm run dev -w @citybrain/api",
    "dev:mobile": "npm run start -w @citybrain/mobile",
    "dev:citizen:flutter": "cd apps/citizen_flutter && flutter run",
    "dev:web": "npm run dev -w @citybrain/web",
    "build:web": "npm run build -w @citybrain/web",
    "db:migrate": "npm run db:migrate -w @citybrain/api",
    "db:seed": "npm run db:seed -w @citybrain/api"
  },
  "engines": {
    "node": ">=20"
  }
}
